# Python Virtual Environment
# This folder is created when you set up a virtual environment for your Python project.
# It contains all the dependencies and packages installed for the project,
# and is not necessary to include in version control since it can be recreated using the requirements.txt file.
venv/
.env

# python cache
# These files are generated by Python to store bytecode-compiled versions of modules,
# which can speed up loading times.
__pycache__/
*.pyc
*.pyo
*.pyd

# Testing
# This folder is created by pytest to store cache and test results.
# Ignoring this folder prevents test artifacts from being committed to the repository,
# which can help keep the project clean and focused on source code.
.pytest_cache/

# Python packaging
# These directories are created when building and distributing Python packages.
build/
dist/
*.egg-info/

# VS Code - IDE
# This is the folder where VS Code stores workspace settings, launch configurations, and other IDE-specific files.
# Ignoring this folder prevents IDE-specific configurations from being committed to the repository, which can be beneficial for keeping the project clean and avoiding conflicts between different developers' IDE setups.
.vscode/

# os junk/files
# These files are generated by the operating system and are not relevant to the project.
# They can be safely ignored to keep the repository clean.
.DS_Store
Thumbs.db
.venv/
.venv/
venv/
*.db
t.ini
how --stat HEAD~4
*.csv
.aws/
*.csv
aws/
chosen-crew/
